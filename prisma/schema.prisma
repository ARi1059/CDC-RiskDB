// Prisma schema —— CDC-RiskDB 黑名单共享机器人
//
// 注意：blacklist 的「同一老师对同一用户仅一条有效记录」唯一性，采用
// 「部分唯一索引」(WHERE deleted_at IS NULL)，软删除行不占名额、删除后可重录。
// Prisma schema 无法声明部分唯一索引，故该索引在迁移 SQL 中手写追加，
// 详见 docs/开发计划-V1.0.md「三、数据模型」与「M1」。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  teacher
}

/// 系统成员（管理员 / 老师）。移除老师为停用：is_active=false，保留行与历史录入。
model User {
  telegramId BigInt   @id @map("telegram_id")
  username   String?  @db.VarChar(255)
  firstName  String?  @map("first_name") @db.VarChar(255)
  role       Role
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("users")
}

/// 共享黑名单记录。软删除：deleted_at 非空即已删除，所有面向用户查询过滤 deleted_at IS NULL。
model Blacklist {
  id               BigInt    @id @default(autoincrement())
  telegramId       BigInt    @map("telegram_id")
  username         String?   @db.VarChar(255)
  firstName        String?   @map("first_name") @db.VarChar(255)
  reason           String    @db.VarChar(100)
  operatorId       BigInt    @map("operator_id")
  operatorUsername String?   @map("operator_username") @db.VarChar(255)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  @@index([telegramId]) // 查询用户：按目标聚合
  @@index([operatorId]) // 我的黑名单：按录入人
  @@map("blacklist")
  // 部分唯一索引 (operator_id, telegram_id) WHERE deleted_at IS NULL —— 见迁移 SQL 手写追加
}

/// 系统公告。
model Announcement {
  id        BigInt   @id @default(autoincrement())
  content   String   @db.Text
  createdBy BigInt   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("announcements")
}

/// 拉黑原因（管理员在系统设置中维护）。label 为入库 / 展示文案；emoji 仅用于键盘前缀显示。
/// 删除原因不影响已录入的 blacklist 记录（reason 存的是文本快照）。
model Reason {
  id        BigInt   @id @default(autoincrement())
  label     String   @unique @db.VarChar(50)
  emoji     String?  @db.VarChar(16)
  sortOrder Int      @default(0) @map("sort_order")
  createdBy BigInt   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("reasons")
}
