# Telegram Bot Token（@BotFather 获取）
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# PostgreSQL 连接串（本地或部署主机上的 PostgreSQL 地址）
DATABASE_URL=postgresql://riskdb:riskdb@localhost:5432/riskdb

# Redis 连接串（本地或部署主机上的 Redis 地址）
REDIS_URL=redis://localhost:6379

# 初始管理员 Telegram 数字ID，逗号分隔，支持多名（启动时逐个 upsert 为 admin）
ADMIN_TELEGRAM_IDS=123456789

# 运行环境：development | production | test
NODE_ENV=development

# 日志级别：fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# 广播限流（条/秒），录入广播逐人推送时的节流上限
BROADCAST_RATE_PER_SEC=25

# 时区（影响录入时间显示）
TZ=Asia/Shanghai
